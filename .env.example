# Copy to backend/.env for local dev, or set these as environment variables.
# All variables are prefixed SCM_.

# A long random string. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SCM_SECRET_KEY=change-me

# Initial admin password, applied only on first run when no users exist.
SCM_ADMIN_PASSWORD=admin

# Optional: override the database (defaults to a SQLite file under the data dir).
# SCM_DATABASE_URL=sqlite+aiosqlite:////data/sickchill-modern.db

# Where the app stores its database/config.
# SCM_DATA_DIR=/data

# Allowed CORS origins (JSON list). For the Vite dev server:
SCM_CORS_ORIGINS=["http://localhost:5173"]

SCM_DEBUG=false
